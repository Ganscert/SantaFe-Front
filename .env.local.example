# ─── Supabase (server-side only — no exponer al browser) ───
# Settings → API en el dashboard de Supabase.
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ─── App ───
# DEBE ser el id de una fila real de la tabla restaurantes (si no, mesas/menú cargan vacíos)
VITE_RESTAURANTE_ID=<uuid del restaurante por defecto>

# ─── Pusher (opcional) ───
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=

# ─── Azul · Pasarela de pago (server-side only — NUNCA exponer al browser) ───
# Página de Pagos de Azul. Sin AZUL_MERCHANT_ID/AZUL_AUTH_KEY reales la integración
# corre en modo "sandbox" (aprobación simulada) para poder probar el flujo completo.
AZUL_MERCHANT_ID=
AZUL_MERCHANT_NAME=Restaurante Santa Fe
AZUL_MERCHANT_TYPE=Restaurante
AZUL_AUTH_KEY=
AZUL_CURRENCY=$
AZUL_ENV=test                       # test | prod
AZUL_PUBLIC_BASE_URL=http://localhost:5173

# ─── Auth (server-side only) ───
# Secreto para firmar los tokens de sesión de la API. Si se omite, se deriva
# del SUPABASE_SERVICE_ROLE_KEY. Genera uno con: openssl rand -hex 32
AUTH_TOKEN_SECRET=

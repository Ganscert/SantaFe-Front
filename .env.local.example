# ─── Supabase ───
# Copiar este archivo a `.env.local` y rellenar.
# Settings → API en el dashboard de Supabase.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Tenant por defecto (coincide con el seed de schema.sql).
# Cambiar solo si creaste otro restaurante.
VITE_RESTAURANTE_ID=00000000-0000-0000-0000-000000000001

# ─── Pusher (sync local existente) ───
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=
